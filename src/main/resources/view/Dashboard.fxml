      <Rectangle fx:id="lblCredits" arcHeight="5.0" arcWidth="5.0" fill="#6e6c6c" height="400.0" stroke="#6e6c6c" strokeType="INSIDE" strokeWidth="0.0" width="124.0" />
      <ImageView fitHeight="124.0" fitWidth="202.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../img/logo.jpg" />
         </image>
      </ImageView>
      <AnchorPane fx:id="dashRoot" layoutX="124.0" prefHeight="400.0" prefWidth="476.0" />
      <Button layoutX="35.0" layoutY="187.0" mnemonicParsing="false" onAction="#btnAdminOnAction" style="-fx-background-color: #2C2C2C;" text="Admin" textAlignment="CENTER" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button layoutX="35.0" layoutY="303.0" mnemonicParsing="false" onAction="#btnStaffOnAction" prefHeight="25.0" prefWidth="54.0" style="-fx-background-color: #2C2C2C;" text="Staff" textAlignment="CENTER" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
